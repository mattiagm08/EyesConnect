<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E0E0E"
    tools:context=".MainCore.MainActivity"
    tools:ignore="ExtraText">

    <!-- Descrizione App -->
    <TextView
        android:id="@+id/textView"
        android:layout_width="358dp"
        android:layout_height="80dp"
        android:fontFamily="@font/abeezee"
        android:text="With EyesConnect you can use old phones and other devices such as cameras by using bluetooth or wifi and scanning a QR code to connect them to each other!"
        android:textAlignment="center"
        android:textColor="#FFFFFF"
        android:textSize="16dp"
        android:typeface="normal"
        app:layout_constraintBottom_toBottomOf="@+id/textView2"
        app:layout_constraintEnd_toEndOf="@+id/textView2"
        app:layout_constraintStart_toStartOf="@+id/textView2"
        app:layout_constraintTop_toTopOf="@+id/textView2"
        app:layout_constraintVertical_bias="0.5"
        tools:ignore="HardcodedText,SpUsage,TextSizeCheck,VisualLintOverlap" />

    <!-- Sfondo Descrizione App -->
    <TextView
        android:id="@+id/textView2"
        android:layout_width="365dp"
        android:layout_height="100dp"
        android:layout_marginTop="100dp"
        android:background="#20FFFFFF"
        android:textColor="#FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Sfondo Titolo App -->
    <TextView
        android:id="@+id/textView3"
        android:layout_width="0dp"
        android:layout_height="73dp"
        android:background="#661AED"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Titolo App -->

    <TextView
        android:id="@+id/textView4"
        android:layout_width="0dp"
        android:layout_height="500dp"
        android:background="#661AED"
        android:layout_marginTop="70dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView" />

    <TextView
        android:id="@+id/textViewTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16sp"
        android:text="EyesConnect"
        android:textColor="#F1F1F1"
        android:textSize="36sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/textView3"
        app:layout_constraintEnd_toEndOf="@+id/textView3"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5"
        tools:ignore="HardcodedText" />

    <!-- Descrizione QR Code -->
    <TextView
        android:id="@+id/textView5"
        android:layout_width="168dp"
        android:layout_height="55dp"
        android:layout_marginStart="15dp"
        android:layout_marginTop="8dp"
        android:text="If you want to view the cameras from this phone, click the button."
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/buttonQRCode"
        tools:ignore="HardcodedText,TextSizeCheck" />

    <!-- Descrizione Scanner -->
    <TextView
        android:id="@+id/textView6"
        android:layout_width="158dp"
        android:layout_height="54dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="15dp"
        android:text="Otherwise, scan it to make it your camera and use the features."
        android:textAlignment="center"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/buttonScanner"
        tools:ignore="HardcodedText,TextSizeCheck" />

    <!-- QR Code Visualizzatore -->
    <ImageView
        android:id="@+id/imageView"
        android:layout_width="200dp"
        android:layout_height="200dp"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="330dp"

        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView2"
        tools:ignore="ContentDescription"
        tools:src="@tools:sample/avatars" />

    <!-- Pannello Principale -->
    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="74dp"
        android:layout_height="128dp"
        android:layout_marginStart="320dp"
        android:layout_marginTop="-25dp"
        android:layout_marginEnd="10dp"
        app:layout_constraintEnd_toEndOf="@+id/textView3"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/sony_xdcam_video_camera_high_definition_video_video_camera_png_image_removebg_preview"
        tools:ignore="ContentDescription,MissingConstraints,VisualLintBounds,ImageContrastCheck" />

    <!-- Televisore QR Code -->

    <ImageView
        android:id="@+id/imageView3"
        android:layout_width="404dp"
        android:layout_height="302dp"
        android:layout_marginTop="280dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.428"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView2"
        app:srcCompat="@drawable/fdb4abda_b623_4802_a6bd_21d36e9540b0_removebg_preview"
        tools:ignore="ContentDescription" />

    <ImageView
        android:id="@+id/imageView10"
        android:layout_width="242dp"
        android:layout_height="298dp"
        android:layout_marginTop="156dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/scan_qr_code_removebg_preview"
        tools:ignore="ContentDescription" />

    <!-- Bottone QR Code -->

    <ImageView
        android:id="@+id/imageView11"
        android:layout_width="149dp"
        android:layout_height="225dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="200dp"
        android:src="@drawable/pic1769941_rl_02_removebg_preview"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="ContentDescription,MissingConstraints" />

    <Button
        android:id="@+id/buttonQRCode"
        android:layout_width="147dp"
        android:layout_height="51dp"
        android:layout_marginStart="25dp"
        android:layout_marginTop="180dp"
        android:backgroundTint="#661AED"
        android:textSize="18sp"
        android:text="QR Code"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textView"
        tools:ignore="HardcodedText" />

    <!-- Bottone Scanner -->
    <Button
        android:id="@+id/buttonScanner"
        android:layout_width="146dp"
        android:layout_height="50dp"
        android:layout_marginEnd="25dp"
        android:layout_marginTop="180dp"
        android:backgroundTint="#661AED"
        android:text="Scanner"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textView"
        tools:ignore="HardcodedText" />

</androidx.constraintlayout.widget.ConstraintLayout>
