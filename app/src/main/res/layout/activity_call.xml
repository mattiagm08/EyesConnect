<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/linearLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".CameraPanel.home.CallActivity">

    <!-- SurfaceViewRenderer per il video locale (video trasmesso dal dispositivo corrente) -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/local_video_view"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_marginBottom="16dp" />

    <!-- SurfaceViewRenderer per il video remoto (video ricevuto dal dispositivo remoto) -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/remote_video_view"
        android:layout_width="match_parent"
        android:layout_height="258dp" />

    <!-- Pulsante per terminare la chiamata -->
    <Button
        android:id="@+id/end_call_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:onClick="endCall"
        android:text="End Call"
        android:textSize="16sp"
        tools:ignore="OnClick" />
</LinearLayout>
