<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:padding="16dp">

    <!-- Testo di richiesta chiamata -->
    <TextView
        android:id="@+id/incoming_call_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        android:text="Incoming Camera Request"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        tools:ignore="HardcodedText" />

    <!-- Bottone Accetta -->

    <!-- Bottone Rifiuta -->
    <Button
        android:id="@+id/accept_call_button"
        android:layout_width="150dp"
        android:layout_height="60dp"
        android:layout_below="@id/incoming_call_text"
        android:layout_alignParentStart="true"
        android:layout_marginStart="10dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="16dp"
        android:text="Accept"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        tools:ignore="HardcodedText,TextContrastCheck" />

    <Button
        android:id="@+id/reject_call_button"
        android:layout_width="150dp"
        android:layout_height="60dp"
        android:layout_below="@id/incoming_call_text"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="10dp"
        android:text="Reject"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        tools:ignore="HardcodedText" />
</RelativeLayout>
